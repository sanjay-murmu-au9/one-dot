<?xml version="1.0" encoding="utf-8"?>
<!--
    Data Extraction Rules for One-Dot (Android 12+ / API 31+)
    Controls what is included in cloud backups (Google Drive) and device-to-device transfers.

    We exclude SharedPreferences entirely because it contains the user's personal
    wallpaper API URL (which embeds their Firebase UID). This data should not be
    backed up or transferred to another device — the user must re-authenticate.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="OneDotPrefs.xml" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="OneDotPrefs.xml" />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
